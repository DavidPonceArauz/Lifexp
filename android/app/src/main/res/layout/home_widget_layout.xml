<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_root_bg"
    android:padding="12dp"
    android:orientation="vertical"
    android:clickable="true">

    <!-- ── HEADER ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="⚔ LifeXP"
            android:textSize="13sp"
            android:textColor="#D4581A"
            android:textStyle="bold"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/widget_level_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LVL 1"
            android:textSize="9sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:background="@drawable/widget_badge_bg"
            android:paddingLeft="8dp"
            android:paddingRight="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp" />

    </LinearLayout>

    <!-- ── XP BAR CARD ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/widget_card_gold"
        android:padding="10dp"
        android:layout_marginBottom="6dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="5dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✨ "
                android:textSize="10sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="EXPERIENCIA"
                android:textSize="7sp"
                android:textColor="#8B5E3C"
                android:fontFamily="monospace"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_xp_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 / 500 XP"
                android:textSize="8sp"
                android:textColor="#C8860A"
                android:fontFamily="monospace"
                android:textStyle="bold" />

        </LinearLayout>

        <ProgressBar
            android:id="@+id/widget_xp_bar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="12dp"
            android:max="100"
            android:progress="0"
            android:progressTint="#C8860A"
            android:progressBackgroundTint="#E8DDD0" />

        <TextView
            android:id="@+id/widget_xp_pct"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="0% al siguiente nivel"
            android:textSize="6sp"
            android:textColor="#A88B75"
            android:fontFamily="monospace"
            android:gravity="end"
            android:layout_marginTop="3dp" />

    </LinearLayout>

    <!-- ── STATS ROW: RACHA + HÁBITOS ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="6dp">

        <!-- RACHA -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/widget_card_orange"
            android:padding="10dp"
            android:gravity="center_horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔥"
                android:textSize="20sp"
                android:gravity="center" />

            <TextView
                android:id="@+id/widget_streak"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="22sp"
                android:textColor="#D4581A"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:gravity="center" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RACHA"
                android:textSize="6sp"
                android:textColor="#8B5E3C"
                android:fontFamily="monospace"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="dias"
                android:textSize="5sp"
                android:textColor="#A88B75"
                android:fontFamily="monospace" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="6dp"
            android:layout_height="match_parent"
            android:background="#F5EFE6"
            android:orientation="vertical" />

        <!-- HÁBITOS HOY -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:orientation="vertical"
            android:background="@drawable/widget_card_green"
            android:padding="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="5dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌿 "
                    android:textSize="10sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HÁBITOS"
                    android:textSize="7sp"
                    android:textColor="#4A7A45"
                    android:fontFamily="monospace"
                    android:textStyle="bold" />

            </LinearLayout>

            <TextView
                android:id="@+id/widget_habit_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="8sp"
                android:textColor="#2C1A0E"
                android:fontFamily="monospace"
                android:layout_marginBottom="2dp"
                android:singleLine="true"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/widget_habit_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="8sp"
                android:textColor="#2C1A0E"
                android:fontFamily="monospace"
                android:layout_marginBottom="2dp"
                android:singleLine="true"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/widget_habit_3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="8sp"
                android:textColor="#2C1A0E"
                android:fontFamily="monospace"
                android:singleLine="true"
                android:ellipsize="end" />

        </LinearLayout>

    </LinearLayout>

    <!-- ── BOTTOM ROW: METAS + TAREAS ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:background="@drawable/widget_card_bg"
            android:padding="8dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎯"
                android:textSize="16sp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginLeft="6dp">

                <TextView
                    android:id="@+id/widget_goals"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="14sp"
                    android:textColor="#D4581A"
                    android:textStyle="bold"
                    android:fontFamily="monospace" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="METAS"
                    android:textSize="5sp"
                    android:textColor="#A88B75"
                    android:fontFamily="monospace" />

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="6dp"
            android:layout_height="match_parent"
            android:background="#F5EFE6"
            android:orientation="vertical" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:background="@drawable/widget_card_bg"
            android:padding="8dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📋"
                android:textSize="16sp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginLeft="6dp">

                <TextView
                    android:id="@+id/widget_tasks"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="14sp"
                    android:textColor="#4A7A45"
                    android:textStyle="bold"
                    android:fontFamily="monospace" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TAREAS"
                    android:textSize="5sp"
                    android:textColor="#A88B75"
                    android:fontFamily="monospace" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
